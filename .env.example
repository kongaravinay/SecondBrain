# ================================================================
# SECOND BRAIN — Environment Configuration
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local — it contains real secrets
# ================================================================

# Choose your AI provider: ollama | groq | claude | gemini | grok
AI_PROVIDER=groq

# --- GROQ (free, recommended) ---
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- OLLAMA (local, free, private) ---
# Install from: https://ollama.com then run: ollama pull qwen2.5:7b
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# --- ANTHROPIC CLAUDE ---
# Get key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=your_claude_key_here
# CLAUDE_MODEL=claude-sonnet-4-6

# --- GOOGLE GEMINI ---
# Get free key at: https://aistudio.google.com
# GOOGLE_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-1.5-flash

# --- xAI GROK ---
# Get key at: https://console.x.ai
# XAI_API_KEY=your_xai_key_here
# GROK_MODEL=grok-3-mini
