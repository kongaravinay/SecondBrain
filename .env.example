# ================================================================
# SECOND BRAIN — Environment Configuration
# Copy this file to .env.local and fill in your values
# ================================================================

# ----------------------------------------------------------------
# CHOOSE YOUR AI PROVIDER
# Options: ollama | groq | claude | gemini
# ----------------------------------------------------------------
AI_PROVIDER=ollama

# ----------------------------------------------------------------
# OLLAMA (local, free, private — recommended for personal use)
# Install: https://ollama.com
# Then run: ollama pull qwen2.5:7b
# ----------------------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ----------------------------------------------------------------
# GROQ (free cloud API, very fast — recommended for deployment)
# Get free key: https://console.groq.com
# ----------------------------------------------------------------
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# ----------------------------------------------------------------
# ANTHROPIC CLAUDE (best quality, small cost)
# Get key: https://console.anthropic.com
# ----------------------------------------------------------------
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-your_key_here
# CLAUDE_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------
# GOOGLE GEMINI (free cloud API)
# Get free key: https://aistudio.google.com
# ----------------------------------------------------------------
# AI_PROVIDER=gemini
# GOOGLE_API_KEY=AIza_your_key_here
# GEMINI_MODEL=gemini-1.5-flash

# ----------------------------------------------------------------
# xAI GROK (powerful reasoning models)
# Get key: https://console.x.ai
# ----------------------------------------------------------------
# AI_PROVIDER=grok
# XAI_API_KEY=xai-your_key_here
# GROK_MODEL=grok-3-mini
